# Copy this to .env for local development
# Never commit .env to GitHub

# Where SQLite stores its file
# On Render this is set to /data (the persistent disk)
# Locally it defaults to ../data/ (auto-created)
DATA_DIR=

# Shared secret between frontend and backend — any random string
SYNC_KEY=wamifugo2024

# Gmail App Password for password reset emails
# Set up at: https://myaccount.google.com/apppasswords
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Your deployed app URL (used in reset email links)
SITE_URL=https://wamifugo.onrender.com

# Port (Render sets this automatically, leave blank locally)
PORT=3001
